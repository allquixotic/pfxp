{
  "name": "pfxp",
  "module": "index.ts",
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.71.1",
    "@quasar/vite-plugin": "1.12.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "6.0.7",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vue-tsc": "3.3.7"
  },
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "server": "bun run index.ts",
    "api": "bun run index.ts",
    "build:client": "bun run scripts/build-info.ts && vite build",
    "build": "bun run build:client",
    "preview": "bun run build && bun run server",
    "dev": "bun run dev.ts",
    "dev:server": "bun --watch run index.ts",
    "dev:client": "bun run scripts/build-info.ts && vite build --watch --mode development",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit",
    "cli": "dotenvx run -- bun run src/cli.ts",
    "cli:headed": "dotenvx run -- bun run src/cli.ts --headed",
    "playwright:install": "bunx playwright install firefox"
  },
  "type": "module",
  "dependencies": {
    "@quasar/extras": "2.0.2",
    "ag-grid-community": "36.0.0",
    "ag-grid-vue3": "36.0.0",
    "fuse.js": "7.4.2",
    "localforage": "1.10.0",
    "playwright": "^1.60.0",
    "quasar": "2.21.2",
    "vue": "3.5.39"
  }
}
